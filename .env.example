# Database
DATABASE_URL="mysql://root:rootpassword@localhost:3306/autodpro"

# Node Environment
NODE_ENV=development

# Email
SMTP_HOST="smtp.zone.eu"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER=""
SMTP_PASSWORD=""

# reCAPTCHA Enterprise
# Client-side site key — SCORE type (invisible, no challenge shown to users)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# Google Cloud project ID
RECAPTCHA_PROJECT_ID=
# Google Cloud API key with reCAPTCHA Enterprise API enabled
# Create at: Cloud Console → APIs & Services → Credentials → Create API Key
RECAPTCHA_API_KEY=your-google-cloud-api-key
