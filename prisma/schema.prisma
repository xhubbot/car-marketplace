generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}
 

model Car {
  id          Int      @id @default(autoincrement())
  make        String
  model       String
  year        Int
  price       Float
  mileage     Int
  location    String
  image       String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}